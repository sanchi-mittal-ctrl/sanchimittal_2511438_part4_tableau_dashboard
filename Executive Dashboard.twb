      <aliases enabled='yes' />
      <column caption='Profit margin' datatype='real' name='[Calculation_0193531262050304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0193531262222337]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales]-[profit]' />
      </column>
      <column caption='Average order value ' datatype='real' name='[Calculation_0193531265265668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([sales])/COUNTD([order_id])' />
      </column>
      <column caption='Return Rate ' datatype='real' name='[Calculation_0193531266183173]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0193531266904070]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 1 THEN &quot;0-1 days (Fast)&quot;&#13;&#10;   ELSEIF [delivery_days] &lt;= 3 THEN &quot;2-3 days (Standard)&quot;&#13;&#10;   ELSEIF [delivery_days] &lt;= 5 THEN &quot;4-5 days (Slow)&quot;&#13;&#10;   ELSE &quot;6+ days (Very Slow)&quot;&#13;&#10;   END' />
      </column>
      <column caption='Discount Tier' datatype='string' name='[Calculation_0193531267252231]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discount] = 0 THEN &quot;0% (No Discount)&quot;&#13;&#10;   ELSEIF [discount] &lt;= 0.15 THEN &quot;5-15%&quot;&#13;&#10;   ELSEIF [discount] &lt;= 0.25 THEN &quot;20-25%&quot;&#13;&#10;   ELSE &quot;30-35%&quot;&#13;&#10;   END' />
      </column>
      <column caption='profit per order' datatype='real' name='[Calculation_0193531267825672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / COUNTD([order_id])' />
      </column>
